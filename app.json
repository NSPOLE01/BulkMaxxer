{
  "expo": {
    "name": "BulkMaxxer",
    "slug": "bulkmaxxer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "bulkmaxxer",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nikhilpolepalli.bulkmaxxer",
      "infoPlist": {
        "NSCameraUsageDescription": "BulkMaxxer uses the camera to scan food barcodes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.nikhilpolepalli.bulkmaxxer",
      "permissions": ["CAMERA"]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "BulkMaxxer uses the camera to scan food barcodes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
